<Window x:Class="RAM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="RAM"
        Height="760"
        Width="1200"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        ShowInTaskbar="True">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="#DDD"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,10,0">
                    <TextBlock Text="Endpoint" FontWeight="Bold"/>
                    <TextBox x:Name="EndpointTextBox"
                             Margin="0,4,0,0"
                             Height="28"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="0,0,10,0">
                    <TextBlock Text="Model" FontWeight="Bold"/>
                    <ComboBox x:Name="ModelComboBox"
                              Margin="0,4,0,0"
                              Height="28"
                              IsEditable="True"
                              IsTextSearchEnabled="True"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Name"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Vertical" Margin="0,0,10,0">
                    <TextBlock Text="Status" FontWeight="Bold"/>
                    <TextBlock x:Name="StatusTextBlock"
                               Text="Not tested"
                               Margin="0,8,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="3"
                        x:Name="TestConnectionButton"
                        Content="Test"
                        Height="32"
                        Width="90"
                        VerticalAlignment="Bottom"
                        Click="TestConnectionButton_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="1.3*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="#DDD"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10"
                    Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Chat"
                                   FontSize="18"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="IntentTitleTextBlock"
                                   Text="Intent: (not set)"
                                   FontSize="11"
                                   Opacity="0.8"
                                   Margin="0,2,0,0"/>
                        <TextBlock x:Name="IntentUpdatedTextBlock"
                                   Text=""
                                   FontSize="11"
                                   Opacity="0.6"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <ListBox Grid.Row="1"
                             x:Name="ChatListBox"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E5E5E5"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8"
                                        Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Role}"
                                                   FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Content}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,6,0,0"/>
                                        <TextBlock Text="{Binding Timestamp}"
                                                   FontSize="11"
                                                   Opacity="0.65"
                                                   Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    BorderBrush="#DDD"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Tools / Output"
                                   FontSize="18"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="WorkspaceTextBlock"
                                   Text="Workspace: (not set)"
                                   FontSize="11"
                                   Opacity="0.7"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <WrapPanel Grid.Row="1" Margin="0,0,0,10">
                        <Button Content="List Folder"
                                Width="100"
                                Margin="0,0,8,8"
                                Click="ListFolderButton_Click"/>
                        <Button Content="Read File"
                                Width="100"
                                Margin="0,0,8,8"
                                Click="ReadFileButton_Click"/>
                        <Button Content="Echo"
                                Width="100"
                                Margin="0,0,8,8"
                                Click="EchoButton_Click"/>
                        <Button Content="Clear Output"
                                Width="100"
                                Margin="0,0,8,8"
                                Click="ClearOutputButton_Click"/>
                        <Button Content="Set Workspace"
                                Width="120"
                                Margin="0,0,8,8"
                                Click="SetWorkspaceButton_Click"/>
			<Button Content="Show Memory"
       				Width="110"
        			Margin="0,0,8,8"
        			Click="ShowMemoryButton_Click"/>
                    </WrapPanel>

                    <TextBox Grid.Row="2"
                             x:Name="OutputTextBox"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             IsReadOnly="True"
                             FontFamily="Consolas"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                BorderBrush="#DDD"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10"
                Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="PromptTextBox"
                         Grid.Column="0"
                         Height="80"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         PreviewKeyDown="PromptTextBox_PreviewKeyDown"/>

                <Button x:Name="SendButton"
                        Grid.Column="1"
                        Content="Send"
                        Width="90"
                        Height="36"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Click="SendButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>